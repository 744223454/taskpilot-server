TASKPILOT_NAME=taskpilot-api
TASKPILOT_HOST=0.0.0.0
TASKPILOT_PORT=8888
TASKPILOT_MODE=release
POSTGRES_PASSWORD=<replace-with-strong-password>
TASKPILOT_DATABASE_DSN=postgres://taskpilot:<replace-with-strong-password>@postgres:5432/taskpilot?sslmode=disable
TASKPILOT_REDIS_HOST=redis:6379
TASKPILOT_REDIS_PASS=<replace-if-needed>
TASKPILOT_REDIS_TYPE=node
TASKPILOT_AUTH_ACCESS_SECRET=<replace-with-long-random-secret>
TASKPILOT_AUTH_ACCESS_EXPIRE=86400
